# 复制本文件为 .env.local，填入你自己的 API Key
# 本地开发用 .env.local；部署时在 Vercel 后台的 Environment Variables 里配置同名变量

# 必填：模型 API Key
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：模型供应商（OpenAI 兼容接口），默认 DeepSeek
# DeepSeek:  LLM_BASE_URL=https://api.deepseek.com   LLM_MODEL=deepseek-chat
# Kimi/月之暗面: LLM_BASE_URL=https://api.moonshot.cn/v1  LLM_MODEL=moonshot-v1-auto
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
